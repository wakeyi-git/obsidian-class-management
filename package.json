{
  "name": "obsidian-class-management",
  "version": "1.39.4",
  "description": "학급 명단, 출결, 생활 기록, 할 일과 체크리스트를 로컬 Markdown으로 관리하는 Obsidian 플러그인",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "node --test tests/*.test.mjs",
    "validate": "node scripts/validate-release.mjs",
    "check": "npm test && npm run build && npm run validate",
    "deploy": "npm run build && node scripts/deploy.mjs",
    "version": "node version-bump.mjs"
  },
  "keywords": [
    "obsidian",
    "classroom",
    "teacher"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "esbuild": "0.25.5",
    "obsidian": "latest",
    "typescript": "^5.8.3"
  },
  "workspaces": [
    "packages/*"
  ]
}
